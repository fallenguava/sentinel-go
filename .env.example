# DVR Configuration
DVR_IP=192.168.1.6
DVR_PORT=80
DVR_USER=admin
DVR_PASS=your_actual_password_here
DVR_NUM_CAMS=7

# Telegram Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_CHAT_ID=

# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=sentinel

# Scheduler Configuration (in minutes)
CRON_INTERVAL_MINUTES=60
ALERT_INTERVAL_SECONDS=60

# Webcam (WSL + Windows ffmpeg)
# Get device name by running in PowerShell: ffmpeg -list_devices true -f dshow -i dummy 2>&1
WEBCAM_DEVICE_NAME=HP TrueVision HD
WEBCAM_FFMPEG_PATH=C:/Users/LENOVO/AppData/Local/Microsoft/WinGet/Links/ffmpeg.exe
WEBCAM_CAPTURE_DIR=F:/SentinelGo/webcam_captures

# Camera Names (optional - for display purposes)
CAM_1_NAME=Camera 1
CAM_2_NAME=Camera 2
CAM_3_NAME=Camera 3
CAM_4_NAME=Camera 4
CAM_5_NAME=Camera 5
CAM_6_NAME=Camera 6
CAM_7_NAME=Camera 7
